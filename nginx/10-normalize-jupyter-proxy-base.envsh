#!/bin/sh

raw="${JUPYTER_PROXY_BASE:-/jupyter}"
raw="$(printf '%s' "$raw" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

case "$raw" in
    "") raw="/jupyter" ;;
    /*) ;;
    *) raw="/$raw" ;;
esac

while [ "$raw" != "/" ] && [ "${raw%/}" != "$raw" ]; do
    raw="${raw%/}"
done

if [ "$raw" = "/" ]; then
    raw="/jupyter"
fi

case "$raw" in
    *[!A-Za-z0-9_./-]*)
        echo "invalid JUPYTER_PROXY_BASE: $raw" >&2
        raw="/jupyter"
        ;;
esac

export NGINX_JUPYTER_PROXY_BASE="$raw"
