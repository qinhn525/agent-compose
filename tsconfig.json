{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["svelte", "vite/client"]
  },
  "include": [
    "frontend/src/**/*.ts",
    "frontend/src/**/*.svelte",
    "frontend/vite.config.ts"
  ]
}
